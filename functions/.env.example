# Variáveis de ambiente das Cloud Functions.
#
# O Firebase carrega automaticamente o arquivo `.env.<firebase-project-id>`
# (NÃO o `.env` puro). Copie este arquivo com o nome correto do seu projeto:
#
#   cp .env.example .env.SEU_PROJECT_ID
#
# Veja o README para detalhes.

# Token da API football-data.org (https://www.football-data.org/client/register).
FOOTBALL_DATA_TOKEN=seu_token_aqui
